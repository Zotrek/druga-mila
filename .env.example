# URL Web App Apps Script (formatka Google) — kończy się na /exec
# Bez tej zmiennej: Word lokalnie, bez auto-numeru i bez zapisu do Sheets
DRUGA_MILA_WEBAPP_URL=https://script.google.com/macros/s/…/exec

# ID arkusza formatki (dokumentacja / przyszłe walidacje)
GOOGLE_FORMATKA_SHEETS_ID=1-qRyFnpjvAI1pZYkVXOUKKV9oYlxGsLidDXCtxYWzS0

# Cache geokodowania (JSON, commitowany). Domyślnie: ./data/geocode-cache.json
# GEOCODE_CACHE_PATH=./data/geocode-cache.json

# Wynik buildu mapy (GitHub Pages = root). Domyślnie: ./index.html
# OUTPUT_HTML=./index.html

# User-Agent Nominatim (opcjonalnie)
# NOMINATIM_USER_AGENT=druga-mila/1.0 (kontakt@example.com)
